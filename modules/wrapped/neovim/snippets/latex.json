{
  "List Environment": {
    "prefix": [ "enum", "list" ],
    "body": [
      "\\begin{itemize}",
      "  \\item $1",
      "\\end{itemize}",
      "$0"
    ],
    "description": "Insert a numbered equation environment"
  },
  "Arrow Left": {
    "prefix": [ "leftarrow", "arrowleft", "sample" ],
    "body": [
      "\\leftarrow$0"
    ],
    "description": "Insert an arrow that points left"
  },
  "Python Code": {
    "prefix": [ "python" ],
    "body": [
      "\\begin{lstlisting}[language=Python, caption=$1]",
      "$2",
      "\\end{lstlisting}",
      "$0"
    ],
    "description": "Insert python code"
  },
  "Code": {
    "prefix": [ "code" ],
    "body": [
      "\\begin{lstlisting}[language=$1, caption=$2]",
      "$3",
      "\\end{lstlisting}",
      "$0"
    ],
    "description": "Insert code"
  }
}
